// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("FARMER") // FARMER, VET
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  cows          Cow[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Cow {
  id            String       @id @default(cuid())
  collarId      String       @unique
  name          String?
  breed         String
  age           Int
  weight        Float
  status        String       @default("Healthy") // Healthy, Warning, Critical
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  sensorData    SensorData[]
  alerts        Alert[]
  vaccinations  Vaccination[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Vaccination {
  id               String   @id @default(cuid())
  name             String   // e.g. FMD, Brucellosis
  dateAdministered DateTime?
  nextDueDate      DateTime
  status           String   @default("Pending") // Pending, Completed
  notes            String?
  cowId            String
  cow              Cow      @relation(fields: [cowId], references: [id], onDelete: Cascade)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model SensorData {
  id          String   @id @default(cuid())
  pulse       Float
  temperature Float
  lat         Float?
  lng         Float?
  battery     Float    @default(100)
  timestamp   DateTime @default(now())
  cowId       String
  cow         Cow      @relation(fields: [cowId], references: [id])
}

model Alert {
  id        String   @id @default(cuid())
  type      String   // Temperature, HeartRate, GeoFence, Tamper
  message   String
  severity  String   // Info, Warning, Critical
  timestamp DateTime @default(now())
  cowId     String
  cow       Cow      @relation(fields: [cowId], references: [id])
  isRead    Boolean  @default(false)
}
